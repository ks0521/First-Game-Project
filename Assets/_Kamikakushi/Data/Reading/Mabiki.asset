  m_Script: {fileID: 11500000, guid: bd5b5cdca608de34dacb632620e4bd35, type: 3}
  m_Name: Mabiki
  m_EditorClassIdentifier: 
  title: "\uACFC\uAC70\uC758 \uC545\uC2B5"
  body: "\uB9C8\uBE44\uD0A4\uB294 \uC5D0\uB3C4 \uC2DC\uB300 \uC77C\uBCF8\uC5D0\uC11C
    \uADF9\uC2EC\uD55C \uC0DD\uD65C\uACE0 \uC18D\uC5D0 \uD589\uD574\uC9C0\uB358\n
    \uC544\uC774\uB97C \uC18E\uC544\uB0B4\uB294 \uC545\uC2B5\uC774\uC5C8\uB2E4.\n\uB2F9\uC2DC
    \uB2E4\uC12F \uC0B4\uC774 \uB418\uC9C0 \uC54A\uC740 \uC544\uC774\uB4E4\uC740
    \uC544\uC9C1 \uC644\uC804\uD55C \uC778\uAC04\uC774 \uC544\uB2C8\uB77C\n \u2018\uC2E0\uC758
    \uC544\uC774\u2019\uB77C \uC5EC\uACA8\uC84C\uACE0\n\uC5B4\uBBF8\uB4E4\uC740 \uC544\uC774\uB97C
    \uC8FD\uC774\uB294 \uAC83\uC774 \uC544\uB2C8\uB77C \uC2E0\uC758 \uC138\uACC4\uB85C
    \uB418\uB3CC\uB824\uBCF4\uB0B4\uB294 \uC77C\uC774\uB77C \n\uC2A4\uC2A4\uB85C\uB97C
    \uC124\uB4DD\uD588\uB2E4.\n\uADF8\uB9AC\uD558\uC5EC \uC0DD\uC874\uC744 \uC704\uD55C
    \uC120\uD0DD\uC774\uB77C\uB294 \uC774\uB984 \uC544\uB798, \n\uC8C4\uCC45\uAC10\uC740
    \uC2E0\uC559\uACFC \uAD00\uC2B5 \uC18D\uC5D0 \uC870\uC6A9\uD788 \uBB3B\uD600\uAC14\uB2E4."
  images: {fileID: 0}
